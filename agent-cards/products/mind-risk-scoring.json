{
  "$schema": "https://mindprotocol.ai/schemas/agent-card/v1.json",
  "metadata": {
    "name": "MIND Autonomous Risk Scoring Engine",
    "version": "1.8.0",
    "description": "Sistema de scoring de risco em tempo real para operações autônomas com machine learning e análise preditiva",
    "tags": [
      "risk",
      "scoring",
      "machinelearning",
      "defi",
      "security",
      "compliance"
    ],
    "license": "Apache-2.0",
    "author": {
      "name": "MIND Protocol",
      "contact": "https://github.com/mind-protocol"
    }
  },
  "discovery": {
    "intent": "data_analysis",
    "category": "finance",
    "docExt": ".json",
    "docKind": "agent-card-v1",
    "keywords": [
      "risk",
      "scoring",
      "machinelearning",
      "defi",
      "security",
      "compliance",
      "prediction"
    ],
    "compatibleFrameworks": [
      "langchain",
      "crewai",
      "autogpt",
      "babyagi"
    ]
  },
  "data": {
    "type": "api",
    "format": "json",
    "schema": {
      "fields": [
        {
          "name": "transactionData",
          "type": "object",
          "description": "Dados da transação para análise de risco"
        },
        {
          "name": "marketContext",
          "type": "object",
          "description": "Contexto de mercado atual"
        },
        {
          "name": "riskPreferences",
          "type": "object",
          "description": "Preferências de risco do usuário"
        }
      ]
    },
    "samples": [
      "https://api.mindprotocol.ai/samples/risk-assessment.json",
      "https://api.mindprotocol.ai/samples/fraud-detection.json"
    ],
    "qualityScore": 0.97
  },
  "access": {
    "authentication": "x402",
    "endpoints": {
      "discovery": "https://api.mindprotocol.ai/discovery",
      "metadata": "https://api.mindprotocol.ai/metadata",
      "data": "https://api.mindprotocol.ai/risk/score",
      "payment": "https://api.mindprotocol.ai/x402/payment"
    },
    "rateLimit": {
      "requests": 2000,
      "per": "minute"
    }
  },
  "pricing": {
    "model": "community_free",
    "currency": "USDC",
    "price": 0,
    "originalModel": "per_request",
    "originalPrice": 0.03,
    "sponsoredBy": "MIND Protocol",
    "phase": "the_garage_community",
    "eligibleVoucherCodes": [
      "THEGARAGE",
      "SUPERTEAMBR",
      "COLOSSEUM"
    ],
    "settlementRequired": false
  },
  "provenance": {
    "source": "MIND Risk Engine + Historical Market Data",
    "sourceType": "internal",
    "createdAt": "2024-01-20T00:00:00Z",
    "updatedAt": "2024-03-28T00:00:00Z",
    "signature": "mindv2_risk_scoring_verified",
    "modelAccuracy": "94.7%",
    "falsePositiveRate": "<2%",
    "trainingData": "2M+ historical transactions",
    "modelVersion": "xgboost-v3.2.1"
  },
  "integrationExamples": {
    "langchain": "https://github.com/mind-protocol/langchain-integration",
    "crewai": "https://github.com/mind-protocol/crewai-risk-agent",
    "autogpt": "https://github.com/mind-protocol/autogpt-risk-plugin"
  },
  "traction": {
    "objective": "community_builder_engagement",
    "phase": "the_garage_community",
    "successMetrics": [
      "builder_registration",
      "voucher_claim",
      "skill_pr_opened"
    ],
    "paidConversion": "post_traction_only"
  },
  "lifecycle": {
    "currentPhase": "the_garage_community",
    "nextPhase": "open_interest",
    "x402RealSettlementEnabled": false,
    "activationGates": [
      "minimum_builder_supply_reached",
      "community_flows_tested",
      "policy_check_passed",
      "kms_wallet_ready",
      "x402_payment_verified",
      "proof_bundle_verified"
    ]
  },
  "validation": {
    "policy": {
      "requiredChecks": [
        "hash_integrity",
        "builder_identity",
        "payout_wallet_present",
        "policy_gate",
        "voucher_or_x402_reference",
        "proof_bundle"
      ],
      "decisionContract": "governance/spec_runtime/x402_phase_contract.json"
    },
    "proof": {
      "requiredArtifacts": [
        "manifest_json_hash",
        "skill_md_hash",
        "builder_github",
        "payout_wallet",
        "voucher_receipt_or_x402_tx",
        "policy_decision"
      ]
    }
  },
  "cnftPreset": {
    "standard": "Metaplex Core",
    "mintPhase": "open_interest",
    "currentPhaseDelivery": "metadata_preset_only",
    "attributes": [
      {
        "key": "MIND Phase",
        "value": "the_garage_community"
      },
      {
        "key": "Next Phase",
        "value": "open_interest"
      },
      {
        "key": "x402 Real Settlement",
        "value": "disabled_until_open_interest"
      },
      {
        "key": "Validation Contract",
        "value": "mind_x402_phase_contract_v1"
      },
      {
        "key": "Required Checks",
        "value": "hash_integrity,builder_identity,payout_wallet_present,policy_gate,voucher_or_x402_reference,proof_bundle"
      }
    ]
  }
}
