{
  "$schema": "https://mindprotocol.ai/schemas/agent-card/v1.json",
  "metadata": {
    "name": "MIND Autonomous Execution Engine",
    "version": "2.0.0",
    "description": "Motor de execução autônoma com zero latência para trades algorítmicos e liquidações atômicas em Solana",
    "tags": [
      "autonomous",
      "trading",
      "defi",
      "solana",
      "execution"
    ],
    "license": "Apache-2.0",
    "author": {
      "name": "MIND Protocol",
      "contact": "https://github.com/mind-protocol"
    }
  },
  "discovery": {
    "intent": "orchestration",
    "category": "finance",
    "docExt": ".json",
    "docKind": "agent-card-v1",
    "keywords": [
      "autonomous",
      "trading",
      "execution",
      "solana",
      "defi",
      "liquidation"
    ],
    "compatibleFrameworks": [
      "langchain",
      "crewai",
      "autogpt",
      "babyagi"
    ]
  },
  "data": {
    "type": "service",
    "format": "json",
    "schema": {
      "fields": [
        {
          "name": "strategy",
          "type": "string",
          "description": "Estratégia de trading a ser executada"
        },
        {
          "name": "parameters",
          "type": "object",
          "description": "Parâmetros específicos da estratégia"
        },
        {
          "name": "riskProfile",
          "type": "string",
          "description": "Perfil de risco (low, medium, high)"
        }
      ]
    },
    "samples": [
      "https://api.mindprotocol.ai/samples/autonomous-trade.json",
      "https://api.mindprotocol.ai/samples/liquidation-execution.json"
    ],
    "qualityScore": 0.98
  },
  "access": {
    "authentication": "x402",
    "endpoints": {
      "discovery": "https://api.mindprotocol.ai/discovery",
      "metadata": "https://api.mindprotocol.ai/metadata",
      "data": "https://api.mindprotocol.ai/execute",
      "payment": "https://api.mindprotocol.ai/x402/payment"
    },
    "rateLimit": {
      "requests": 1000,
      "per": "minute"
    }
  },
  "pricing": {
    "model": "community_free",
    "currency": "USDC",
    "price": 0,
    "originalModel": "per_request",
    "originalPrice": 0.05,
    "sponsoredBy": "MIND Protocol",
    "phase": "the_garage_community",
    "eligibleVoucherCodes": [
      "THEGARAGE",
      "SUPERTEAMBR",
      "COLOSSEUM"
    ],
    "settlementRequired": false
  },
  "provenance": {
    "source": "MIND Protocol Treasury",
    "sourceType": "internal",
    "createdAt": "2024-01-15T00:00:00Z",
    "updatedAt": "2024-03-20T00:00:00Z",
    "signature": "mindv2_autonomous_execution_verified",
    "performanceHistory": "https://dashboard.mindprotocol.ai/performance",
    "auditLogs": "https://github.com/mind-protocol/audit-logs"
  },
  "traction": {
    "objective": "community_builder_engagement",
    "phase": "the_garage_community",
    "successMetrics": [
      "builder_registration",
      "voucher_claim",
      "skill_pr_opened"
    ],
    "paidConversion": "post_traction_only"
  },
  "lifecycle": {
    "currentPhase": "the_garage_community",
    "nextPhase": "open_interest",
    "x402RealSettlementEnabled": false,
    "activationGates": [
      "minimum_builder_supply_reached",
      "community_flows_tested",
      "policy_check_passed",
      "kms_wallet_ready",
      "x402_payment_verified",
      "proof_bundle_verified"
    ]
  },
  "validation": {
    "policy": {
      "requiredChecks": [
        "hash_integrity",
        "builder_identity",
        "payout_wallet_present",
        "policy_gate",
        "voucher_or_x402_reference",
        "proof_bundle"
      ],
      "decisionContract": "governance/spec_runtime/x402_phase_contract.json"
    },
    "proof": {
      "requiredArtifacts": [
        "manifest_json_hash",
        "skill_md_hash",
        "builder_github",
        "payout_wallet",
        "voucher_receipt_or_x402_tx",
        "policy_decision"
      ]
    }
  },
  "cnftPreset": {
    "standard": "Metaplex Core",
    "mintPhase": "open_interest",
    "currentPhaseDelivery": "metadata_preset_only",
    "attributes": [
      {
        "key": "MIND Phase",
        "value": "the_garage_community"
      },
      {
        "key": "Next Phase",
        "value": "open_interest"
      },
      {
        "key": "x402 Real Settlement",
        "value": "disabled_until_open_interest"
      },
      {
        "key": "Validation Contract",
        "value": "mind_x402_phase_contract_v1"
      },
      {
        "key": "Required Checks",
        "value": "hash_integrity,builder_identity,payout_wallet_present,policy_gate,voucher_or_x402_reference,proof_bundle"
      }
    ]
  }
}
