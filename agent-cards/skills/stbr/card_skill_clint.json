        },
        {
          "name": "uid_hash",
          "type": "string",
          "description": "SHA-256 of Firebase UID, hex-encoded (64 chars). First 16 bytes are the Anchor PDA seed."
        },
        {
          "name": "window_hours",
          "type": "number",
          "description": "Analysis window in hours (1–720). Default: 24."
        },
        {
          "name": "mode",
          "type": "string",
          "description": "quick | full | sybil_check. Default: full."
        }
      ]
    },
    "samples": [
      {
        "input": {
