{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Solana Ecosystem Signal",
  "type": "object",
  "properties": {
    "protocol_name": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "source_type": { 
      "type": "string", 
      "enum": [
        "blog", "docs", "changelog", "product_page", "x_post", 
        "institutional_announcement", "press_release", "governance_forum"
      ] 
    },
    "published_at": { "type": "string", "format": "date-time" },
    "headline": { "type": "string" },
    "summary": { "type": "string" },
    "claim_type": { 
      "type": "string",
      "enum": [
        "integration", "partnership", "product_launch", "risk_incident", 
        "liquidity_program", "incentive_program", "compliance_update", "company_claim"
      ]
    },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "content_hash": { "type": "string" },
    "first_seen_at": { "type": "string", "format": "date-time" },
    "last_seen_at": { "type": "string", "format": "date-time" },
    "classification_layer": { 
      "type": "string", 
      "enum": ["public_ecosystem_signal", "verified_onchain_metric"] 
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "extraction_warnings": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "protocol_name", "source_url", "source_type", "published_at", 
    "headline", "summary", "claim_type", "confidence_score", 
    "content_hash", "last_seen_at", "classification_layer"
  ]
}