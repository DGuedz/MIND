{
  "version": "1.0",
  "auth": {
    "header_name": "x-event-router-token",
    "token_env": "EVENT_ROUTER_SERVICE_TOKEN",
    "required": true
  },
  "rate_limit": {
    "window_sec": 60,
    "max_requests_per_window": 120
  },
  "replay_protection": {
    "enabled": true,
    "ttl_sec": 900
  },
  "duplicate_suppression": {
    "enabled": true,
    "ttl_sec": 60
  },
  "limits": {
    "max_slippage_bps": 50,
    "max_retry": 3,
    "proof_timeout_sec": 120,
    "anchor_timeout_sec": 180
  },
  "circuit_breaker": {
    "enabled": true,
    "failure_window_sec": 300,
    "failure_threshold": 2,
    "open_sec": 30
  }
}