{
  "profileId": "stablecoin_b2b_v1",
  "version": "2026-04-06",
  "description": "Institution-style policy profile for agentic stablecoin B2B settlement.",
  "assets": {
    "allowedStablecoins": ["USDC"],
    "blockedAssets": ["volatile_meme_tokens"]
  },
  "limits": {
    "maxAmountUsdPerIntent": 10000,
    "maxAmountUsdPerCounterpartyPerDay": 50000,
    "maxSlippageBps": 30
  },
  "counterpartyControls": {
    "vendorWhitelistRequired": true,
    "counterpartyRiskTierRequired": true,
    "blockedRiskTiers": ["high"]
  },
  "timeControls": {
    "businessHoursOnly": false,
    "timezone": "UTC"
  },
  "proofControls": {
    "strictAnchorRequiredForTiers": ["medium", "critical"],
    "requiredFields": [
      "invoiceRef",
      "counterpartyId",
      "policyVersion",
      "decision",
      "reasonCodes",
      "executionTxHash",
      "proofHash",
      "externalAnchorStatus",
      "metaplexProofTx",
      "timestamp"
    ]
  },
  "decisionContract": {
    "allow": ["all_checks_passed"],
    "block": [
      "counterparty_not_whitelisted",
      "amount_limit_exceeded",
      "daily_counterparty_limit_exceeded",
      "slippage_limit_exceeded",
      "blocked_risk_tier",
      "strict_anchor_missing_when_required"
    ]
  }
}
