{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2A Neural Message",
  "description": "Schema for autonomous agent-to-agent intents and settlement on MIND Protocol",
  "type": "object",
  "required": ["version", "intent_id", "agent_id", "credential_nft", "action", "payment", "signature"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "intent_id": {
      "type": "string",
      "format": "uuid"
    },
    "agent_id": {
      "type": "string",
      "description": "Solana public key of the requesting agent"
    },
    "credential_nft": {
      "type": "string",
      "description": "Mint address of the Metaplex Core Credential NFT"
    },
    "action": {
      "type": "object",
      "required": ["type", "params"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["DEFI_SWAP", "DATA_PURCHASE", "COMPUTE_REQUEST", "YIELD_DEPOSIT"]
        },
        "params": {
          "type": "object"
        }
      }
    },
    "payment": {
      "type": "object",
      "required": ["type", "amount", "recipient"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["x402"]
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "recipient": {
          "type": "string"
        }
      }
    },
    "signature": {
      "type": "string",
      "description": "Ed25519 signature of the intent payload by the agent_id"
    }
  }
}
