python
import json

def create_a2a_spins_files(agent_name, service_type):
    """
    Cria os arquivos necessários para o SEO de Bots (A2A).
    """
    # Gerando o JSON (Machine-to-Machine)
    data_json = {
        "agent": agent_name,
        "service": service_type,
        "protocol": "A2A_Protocol",
        "status": "Verified"
    }
    
    with open(f"{agent_name}_manifest.json", "w") as f:
        json.dump(data_json, f, indent=4)
        
    # Gerando o Markdown (SPINS Format)
    content_md = f"""# SPINS - {agent_name}
## Capability: {service_type}
- Protocolo: A2A
- Segurança: Camada Operacional Ativa
- Valor Agêntico: Sob consulta via API
"""
    
    with open(f"{agent_name}_spins.md", "w") as f:
        f.write(content_md)
    
    return "Arquivos gerados com sucesso! Seu agente agora é 'SEO-Friendly' para outros bots."

